N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://SEU_IP:5678/

GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

N8N_ENCRYPTION_KEY=troque-por-chave-forte
N8N_SECURE_COOKIE=false

# N8N usa SQLite por padrao (volume n8n_data).
# Para usar PostgreSQL, descomentar e criar o banco n8n manualmente:
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=postgres
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=clientezero
# DB_POSTGRESDB_PASSWORD=troque-por-senha-forte
