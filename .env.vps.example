# VPS environment — copy to .env.vps and fill values before running scripts/vps-deploy.sh

DOMAIN=seudominio.com
NEXT_PUBLIC_APP_URL=https://seudominio.com

# PostgreSQL (usado pelo Docker e pelo Next.js)
POSTGRES_PASSWORD=troque-por-senha-forte
DATABASE_URL=postgres://clientezero:troque-por-senha-forte@postgres:5432/clientezero

# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-xxx
WEBHOOK_SECRET=troque-por-segredo-forte

# Evolution API (WhatsApp) — container interno, API key definida aqui
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=troque-por-chave-evolution-forte
EVOLUTION_INSTANCE=instancia

# Admin
ADMIN_WHATSAPP=5535999999999
ADMIN_TOKEN=troque-por-token-admin-minimo-16-chars
CRON_SECRET=troque-por-secret-cron-minimo-16-chars
